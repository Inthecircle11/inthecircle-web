# WordPress REST API – for publish-posts-to-wordpress.js
# Copy to .env and fill in. Do not commit .env.

WORDPRESS_URL=https://inthecircle.co
WORDPRESS_USER=admin
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional: if your WordPress sitemap URL is different (e.g. post-sitemap.xml only)
# WORDPRESS_SITEMAP=https://inthecircle.co/sitemap_index.xml
# APP_SITEMAP=https://app.inthecircle.co/sitemap.xml
