# SFTP/SCP upload for ITC landing (upload-itc-landing-sftp.mjs)
# Copy to .env.sftp and fill in. Do not commit .env.sftp.

WP_SFTP_HOST=your-server.com
WP_SFTP_USER=your-ssh-user
# Optional: full path to theme on server (default: wp-content/themes/extendable)
# WP_SFTP_REMOTE_PATH=/home/username/public_html/wp-content/themes/extendable
# Optional: SSH password (if not using key)
# WP_SFTP_PASSWORD=your-password
# Optional: path to SSH private key (else password auth)
# WP_SFTP_KEY=/path/to/private/key
# Optional: port (default 22). Many shared hosts use 2222 for SFTP.
# WP_SFTP_PORT=22
# WP_SFTP_PORT=2222
