{"element":"Code editor textarea","ref":"e15","value":"<!-- wp:html -->\n<style id=\"itc-blog-chrome\">\n.itc-page *, .itc-page *::before, .itc-page *::after {box-sizing:border-box;margin:0;padding:0}\n.itc-page { --p:#6366F1;--p2:#8B5CF6;--p3:#A78BFA;--pk:#EC4899;--pk2:#F472B6; --bg:#04040A;--bg2:#080810;--s:#131320;--b:rgba(99,102,241,.1);--b2:rgba(99,102,241,.22); --t:#ECEEFF;--t2:rgba(236,238,255,.82);--t3:rgba(236,238,255,.58); font-family:'Plus Jakarta Sans',sans-serif; background:var(--bg);color:var(--t); overflow-x:hidden;-webkit-font-smoothing:antialiased; }\nbody:has(.itc-page){background:#04040A!important;overflow-x:hidden}\n.wp-site-blocks:has(.itc-page),.entry-content:has(.itc-page),.page-content:has(.itc-page){padding:0!important;margin:0!important}\n.itc-page nav{position:fixed;top:0;left:0;right:0;z-index:100;height:70px;padding:0 56px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid transparent;transition:all .4s;}\nbody.admin-bar .itc-page nav{top:32px!important}\nbody.admin-bar .itc-page{margin-top:-32px!important}\n.itc-page nav.on {background:rgba(4,4,10,.88);backdrop-filter:blur(24px) saturate(160%);border-color:var(--b)}\n.itc-page .nb {display:flex;align-items:center;gap:10px;text-decoration:none}\n.itc-page .nb img {width:34px;height:34px;border-radius:9px;object-fit:cover}\n.itc-page .nb-t {font-size:16px;font-weight:700;letter-spacing:-.025em;color:var(--t)!important;font-family:'Plus Jakarta Sans',sans-serif}\n.itc-page .nl {display:flex;gap:36px;align-items:center}\n.itc-page .nl a {font-size:13.5px;font-weight:500;color:var(--t2)!important;text-decoration:none;transition:color .2s;letter-spacing:-.01em}\n.itc-page .nl a:hover {color:var(--t)!important;}\n.itc-page .ndl {background:var(--p);color:#fff!important;padding:10px 22px;border-radius:8px;font-weight:600!important;font-size:13px!important;transition:background .2s,box-shadow .2s!important;box-shadow:0 4px 18px rgba(99,102,241,.28)}\n.itc-page .ndl:hover {background:#4f50d4!important;box-shadow:0 8px 30px rgba(99,102,241,.48)!important}\n.itc-page footer{padding:44px 56px;border-top:1px solid var(--b);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px;background:var(--bg)}\n.itc-page .f-brand {display:flex;align-items:center;gap:10px;text-decoration:none}\n.itc-page .f-brand img {width:28px;height:28px;border-radius:8px;object-fit:cover}\n.itc-page .f-brand-n {font-size:15px;font-weight:700;letter-spacing:-.025em;color:var(--t)}\n.itc-page .f-links {display:flex;gap:24px;flex-wrap:wrap;align-items:center}\n.itc-page .f-links a {font-size:11px;color:var(--t3)!important;text-decoration:none;letter-spacing:.08em;text-transform:uppercase;font-family:'DM Mono',monospace;transition:color .2s}\n.itc-page .f-links a:hover {color:var(--p3)!important;}\n.itc-page .f-social {display:flex;gap:14px;align-items:center}\n.itc-page .f-social a {display:flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:10px;background:var(--s);border:1px solid var(--b);color:var(--t3)!important;transition:color .2s,background .2s,border-color .2s}\n.itc-page .f-social a:hover {color:var(--p3)!important;background:rgba(99,102,241,.1);border-color:var(--b2)}\n.itc-page .f-social svg {width:18px;height:18px;fill:currentColor}\n.itc-page .f-copy {font-size:11px;color:var(--t3)!important;font-family:'DM Mono',monospace}\n/* Push main content below fixed nav so language filter and pagination don't overlap menu */\n.itc-page main.wp-block-group { padding-top: 90px !important; padding-bottom: 0 !important; }\nbody.admin-bar .itc-page main.wp-block-group { padding-top: 122px !important; }\n/* Keep language filter below nav (plugin injects it into main) */\n#itc-blog-lang-filter { position: relative !important; z-index: 1 !important; margin-top: 0 !important; }\n.itc-page nav { z-index: 100 !important; }\n/* Force pagination to appear AFTER the blog posts (main is often outside .itc-page) */\nbody.blog main .wp-block-query,\nbody.home main .wp-block-query,\n.itc-page main .wp-block-query,\n.itc-page .wp-block-query { display: flex !important; flex-direction: column !important; }\nbody.blog main .wp-block-query .wp-block-post-template,\nbody.home main .wp-block-query .wp-block-post-template,\n.itc-page main .wp-block-query .wp-block-post-template,\n.itc-page .wp-block-query .wp-block-post-template { order: 1 !important; }\nbody.blog main .wp-block-query .wp-block-query-pagination,\nbody.home main .wp-block-query .wp-block-query-pagination,\n.itc-page main .wp-block-query .wp-block-query-pagination,\n.itc-page .wp-block-query .wp-block-query-pagination { order: 2 !important; margin-top: 48px !important; }\nbody.blog main .wp-block-query .wp-block-query-no-results,\nbody.home main .wp-block-query .wp-block-query-no-results,\n.itc-page .wp-block-query .wp-block-query-no-results,\n.itc-page .wp-block-query .wp-block-query-no-results { order: 2 !important; }\n/* Hide pagination when it appears before content (script moves it after posts) */\nbody.blog main .wp-block-query-pagination:not(:last-child),\nbody.home main .wp-block-query-pagination:not(:last-child) { opacity: 0 !important; pointer-events: none !important; position: absolute !important; left: -9999px !important; }\nbody.blog main .wp-block-query-pagination:last-child,\nbody.home main .wp-block-query-pagination:last-child,\n.wp-block-query-pagination[style*=\"margin-top\"] { opacity: 1 !important; margin-top: 48px !important; display: flex !important; justify-content: center !important; flex-wrap: wrap !important; }\n@media(max-width:1050px){ .itc-page nav{padding:0 22px} .itc-page .nl {display:none} .itc-page footer {flex-direction:column;text-align:center;padding:32px 22px} .itc-page .f-links,.itc-page .f-social {justify-content:center} }\n</style>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Fraunces:ital,wght@0,300;0,400;1,300;1,400&family=DM+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n\n<div class=\"itc-page\">\n<nav id=\"nav\">\n  <a href=\"/\" class=\"nb\">\n    <img src=\"/wp-content/themes/extendable/assets/images/itc-landing-1.png\" alt=\"InTheCircle\">\n    <span class=\"nb-t\">InTheCircle</span>\n  </a>\n  <div class=\"nl\">\n    <a href=\"/#screens\">App</a>\n    <a href=\"/#features\">Features</a>\n    <a href=\"/#community\">Community</a>\n    <a href=\"/#pricing\">Pricing</a>\n    <a href=\"/blog/\">Blog</a>\n    <a href=\"/#download\" class=\"ndl\">Download</a>\n  </div>\n</nav>\n<script>\n(function(){\n  function movePaginationToBottom() {\n    var main = document.querySelector('main') || document.querySelector('[role=\"main\"]');\n    if (!main) return;\n    var queryBlock = main.querySelector('.wp-block-query');\n    var pagination = document.querySelector('.wp-block-query-pagination');\n    if (!pagination) return;\n    var targetParent = queryBlock ? queryBlock.parentNode : main;\n    var insertAfter = queryBlock || main.querySelector('.wp-block-post-template');\n    if (insertAfter) {\n      if (pagination.parentNode !== targetParent || pagination.nextElementSibling) {\n        targetParent.insertBefore(pagination, insertAfter.nextElementSibling);\n      }\n    } else {\n      if (pagination.parentNode !== main) main.appendChild(pagination);\n      else if (pagination.nextElementSibling) main.appendChild(pagination);\n    }\n    pagination.style.marginTop = '48px';\n  }\n  function run() {\n    movePaginationToBottom();\n    setTimeout(movePaginationToBottom, 150);\n    setTimeout(movePaginationToBottom, 600);\n  }\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', run);\n  } else {\n    run();\n  }\n  window.addEventListener('load', movePaginationToBottom);\n})();\n</script>\n<!-- /wp:html -->\n\n<!-- ========== BLOCK 2: Your existing blog content (main + query) goes here as normal blocks ========== -->\n<!-- wp:group {\"tagName\":\"main\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"0\",\"bottom\":\"0\"}}},\"backgroundColor\":\"\",\"layout\":{\"type\":\"constrained\",\"contentSize\":\"1200px\"}} -->\n<main class=\"wp-block-group\" style=\"padding-top:0;padding-bottom:0\">\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"120px\",\"bottom\":\"60px\"}}},\"layout\":{\"type\":\"constrained\",\"contentSize\":\"800px\"}} -->\n<div class=\"wp-block-group\" style=\"padding-top:120px;padding-bottom:60px\">\n<!-- wp:heading {\"level\":1,\"textAlign\":\"center\",\"style\":{\"typography\":{\"fontFamily\":\"Fraunces, serif\",\"fontWeight\":\"300\",\"letterSpacing\":\"-0.03em\"},\"color\":{\"text\":\"#ECEEFF\"}}} -->\n<h1 class=\"wp-block-heading has-text-align-center\" style=\"color:#ECEEFF;font-family:Fraunces,serif;font-weight:300;letter-spacing:-0.03em\">Latest from <em>InTheCircle</em></h1>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph {\"align\":\"center\",\"style\":{\"color\":{\"text\":\"rgba(236,238,255,0.52)\"},\"typography\":{\"fontSize\":\"17px\"}}} -->\n<p class=\"has-text-align-center\" style=\"color:rgba(236,238,255,0.52);font-size:17px\">Insights, updates and stories from the creator community.</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"0\",\"bottom\":\"100px\",\"left\":\"48px\",\"right\":\"48px\"}}},\"layout\":{\"type\":\"constrained\",\"contentSize\":\"1200px\"}} -->\n<div class=\"wp-block-group\" style=\"padding-bottom:100px;padding-left:48px;padding-right:48px\">\n<!-- wp:query {\"queryId\":1,\"query\":{\"perPage\":10,\"pages\":0,\"offset\":0,\"postType\":\"post\",\"order\":\"desc\",\"orderBy\":\"date\",\"author\":\"\",\"search\":\"\",\"exclude\":[],\"sticky\":\"\",\"inherit\":true}} -->\n<div class=\"wp-block-query\">\n<!-- wp:post-template {\"layout\":{\"type\":\"grid\",\"columnCount\":2}} -->\n\n<!-- wp:group {\"style\":{\"border\":{\"radius\":\"18px\"},\"spacing\":{\"padding\":{\"top\":\"32px\",\"bottom\":\"32px\",\"left\":\"32px\",\"right\":\"32px\"}}},\"backgroundColor\":\"\",\"className\":\"itc-blog-card\",\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group itc-blog-card\" style=\"border-radius:18px;padding:32px\">\n\n<!-- wp:post-featured-image {\"isLink\":true,\"style\":{\"border\":{\"radius\":\"12px\"},\"spacing\":{\"margin\":{\"bottom\":\"20px\"}}}} /-->\n\n<!-- wp:post-terms {\"term\":\"category\",\"style\":{\"color\":{\"text\":\"#A78BFA\"},\"typography\":{\"fontSize\":\"10px\",\"fontFamily\":\"DM Mono, monospace\",\"letterSpacing\":\"0.12em\",\"textTransform\":\"uppercase\"}}} /-->\n\n<!-- wp:post-title {\"isLink\":true,\"style\":{\"typography\":{\"fontFamily\":\"Fraunces, serif\",\"fontWeight\":\"400\",\"fontSize\":\"22px\",\"letterSpacing\":\"-0.02em\"},\"color\":{\"text\":\"#ECEEFF\"},\"spacing\":{\"margin\":{\"top\":\"8px\",\"bottom\":\"12px\"}}}} /-->\n\n<!-- wp:post-excerpt {\"moreText\":\"\",\"style\":{\"color\":{\"text\":\"rgba(236,238,255,0.52)\"},\"typography\":{\"fontSize\":\"14px\",\"lineHeight\":\"1.72\"}}} /-->\n\n<!-- wp:post-date {\"style\":{\"color\":{\"text\":\"rgba(236,238,255,0.3)\"},\"typography\":{\"fontSize\":\"10px\",\"fontFamily\":\"DM Mono, monospace\",\"letterSpacing\":\"0.12em\",\"textTransform\":\"uppercase\"},\"spacing\":{\"margin\":{\"top\":\"16px\"}}}} /-->\n\n</div>\n<!-- /wp:group -->\n\n<!-- /wp:post-template -->\n\n<!-- wp:query-pagination {\"layout\":{\"type\":\"flex\",\"justifyContent\":\"center\"},\"style\":{\"spacing\":{\"margin\":{\"top\":\"48px\"}}}} -->\n<!-- wp:query-pagination-previous /-->\n<!-- wp:query-pagination-numbers /-->\n<!-- wp:query-pagination-next /-->\n<!-- /wp:query-pagination -->\n\n<!-- wp:query-no-results -->\n<!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"rgba(236,238,255,0.5)\"},\"typography\":{\"fontSize\":\"16px\"},\"spacing\":{\"padding\":{\"top\":\"60px\",\"bottom\":\"60px\"}}},\"align\":\"center\"} -->\n<p class=\"has-text-align-center\" style=\"color:rgba(236,238,255,0.5);font-size:16px;padding-top:60px;padding-bottom:60px\">No posts yet. Check back soon.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:query-no-results -->\n\n</div>\n<!-- /wp:query -->\n</div>\n<!-- /wp:group -->\n\n</main>\n<!-- /wp:group -->\n\n<!-- ========== BLOCK 3: Paste this in a Custom HTML block BELOW your blog content ========== -->\n<!-- wp:html -->\n<footer>\n  <a href=\"/\" class=\"f-brand\">\n    <img src=\"/wp-content/themes/extendable/assets/images/itc-landing-9.png\" alt=\"ITC\">\n    <span class=\"f-brand-n\">InTheCircle</span>\n  </a>\n  <div class=\"f-links\">\n    <a href=\"/privacy-policy/\">Privacy</a><a href=\"/terms/\">Terms</a><a href=\"/faq/\">FAQ</a>\n    <a href=\"https://app.inthecircle.co/download\" target=\"_blank\" rel=\"noopener\">Download</a>\n    <span class=\"f-social\">\n      <a href=\"https://www.linkedin.com/company/inthecirclee/\" target=\"_blank\" rel=\"noopener\" aria-label=\"LinkedIn\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\"><path d=\"M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z\"/></svg></a>\n      <a href=\"https://www.instagram.com/inthecirclee\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\"><path d=\"M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 