# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (required for password reset link in email to point to the app, not marketing site)
# Set to https://app.inthecircle.co in production. Supabase must also have Site URL = this and Redirect URLs include it.
NEXT_PUBLIC_APP_URL=https://app.inthecircle.co

# Supabase service role (required for admin panel – applications list and other admin APIs)
# Get from Supabase Dashboard → Settings → API → service_role key. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel access (required for /admin) - SERVER-SIDE ONLY, never expose
# Comma-separated list of admin user IDs and emails
ADMIN_USER_IDS=uuid1,uuid2
ADMIN_EMAILS=admin@example.com

# Optional: gate password for /admin (must be entered before login prompt)
# If set, users must enter this password to see the admin login/panel
ADMIN_GATE_PASSWORD=

# Optional: obscure admin URL so /admin returns 404 and only this path works.
# Use a LONG random string (24+ chars recommended). Never commit the real value.
# Generate one: node -e "console.log(require('crypto').randomBytes(16).toString('base64url'))"
# When set: only https://yourapp.com/YOUR_VALUE serves the admin panel; /admin and /admin/* return 404.
# Use the obscure URL (e.g. /abc123...) to open the admin panel.
ADMIN_BASE_PATH=

# Optional: when ADMIN_BASE_PATH is set, direct /admin is allowed by default.
# Set to true to hide /admin (only the obscure path will work).
ADMIN_DISABLE_DIRECT_ACCESS=

# Legacy: ADMIN_ALLOW_DIRECT_ACCESS is no longer needed; /admin is allowed by default.
# ADMIN_ALLOW_DIRECT_ACCESS=

# Optional: IP allowlist for admin (max security). Comma-separated IPs; only these can open admin.
# Leave empty to allow any IP. Use with ADMIN_GATE_PASSWORD and MFA for admins.
ADMIN_ALLOWED_IPS=

# App Store URL (optional - used for iOS app download links)
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/in-the-circle/id123456789

# Optional: Announce (admin panel) — email via Resend
# Get API key from https://resend.com . From must be a verified domain in Resend.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=announcements@yourdomain.com
# Optional: comma-separated test emails when not using segment (e.g. for testing)
# RESEND_ANNOUNCE_TO=admin@example.com,test@example.com

# Supabase: Add these to Auth > URL Configuration > Redirect URLs:
# - https://your-domain.com/auth/callback
# - https://your-domain.vercel.app/auth/callback
